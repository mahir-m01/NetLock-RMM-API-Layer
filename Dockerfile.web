# ─── Dependencies ─────────────────────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
COPY src/ControlIT.Web/package*.json ./
RUN npm ci --prefer-offline

# ─── Builder ──────────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY src/ControlIT.Web .

# NEXT_PUBLIC_API_URL must be set at build time because Next.js inlines it into the bundle.
# The browser accesses the API via the host machine's localhost port mapping.
ARG NEXT_PUBLIC_API_URL=http://localhost:5290
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

RUN npm run build

# ─── Runner ───────────────────────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

# Copy standalone output (includes server.js + required node_modules)
COPY --from=builder /app/.next/standalone ./
# Static assets must be copied separately into the standalone tree
COPY --from=builder /app/.next/static ./.next/static
# Public folder for static files
COPY --from=builder /app/public ./public

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "server.js"]
