# NetLock RMM — Environment Template
# Run ./scripts/setup-controlit-env.sh to create .env with generated secrets.

MYSQL_ROOT_PASSWORD=GENERATED_BY_SETUP_SCRIPT
MYSQL_DATABASE=iphbmh
MEMBERS_PORTAL_API_KEY=get-from-members.netlockrmm.com
TZ=Asia/Kolkata

# ─── ControlIT ────────────────────────────────────────────────────────────────
CONTROLIT_JWT_SIGNING_KEY=GENERATED_BY_SETUP_SCRIPT
CONTROLIT_BOOTSTRAP_EMAIL=admin@yourdomain.local
CONTROLIT_BOOTSTRAP_PASSWORD=GENERATED_BY_SETUP_SCRIPT
CONTROLIT_NETLOCK_TOKEN=REPLACE_WITH_REMOTE_SESSION_TOKEN_FROM_ACCOUNTS_TABLE
CONTROLIT_NETLOCK_FILES_KEY=REPLACE_WITH_NETLOCK_FILES_API_KEY
CONTROLIT_AUTO_MIGRATE=false

# Netbird Management API. Use self-hosted URL or Netbird cloud URL.
# Auth scheme is "Authorization: Token <NETBIRD_TOKEN>" inside ControlIT.
NETBIRD_BASE_URL=https://api.netbird.io
NETBIRD_TOKEN=REPLACE_WITH_NETBIRD_PERSONAL_ACCESS_TOKEN

# Database credentials for the dedicated ControlIT API user (not root).
# See scripts/init-controlit-db-user.sql to create this user in MySQL.
CONTROLIT_DB_USER=controlit_api
CONTROLIT_DB_PASSWORD=GENERATED_BY_SETUP_SCRIPT
