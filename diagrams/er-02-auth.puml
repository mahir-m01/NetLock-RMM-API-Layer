@startuml er-02-expanded
' ============================================================
' ER-02: ControlIT.Api — Expanded ER model
' Scope : Contract 05 §5.2 (NetLock read-only tables)
'         + Contract 05B §5B.2 (controlit_users, refresh tokens,
'           password reset tokens)
' Legend: PK  primary key   FK  foreign key   U  unique
'         +---+ (read-only, NetLock-owned)
'         [==] (ControlIT-owned, EF migrations only)
' ============================================================

title ER-02: NetLock read-only + ControlIT owned — Contracts 05 + 05B

!define PK <b><color:#B71C1C>PK</color></b>
!define FK <b><color:#0D47A1>FK</color></b>
!define U  <b><color:#1B5E20>U</color></b>

skinparam linetype ortho
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam class {
  BackgroundColor<<netlock>> #FFF8E1
  BorderColor<<netlock>>     #AA8800
  BackgroundColor<<controlit>> #E8F5E9
  BorderColor<<controlit>>     #1B5E20
  BackgroundColor<<auth>>    #E3F2FD
  BorderColor<<auth>>        #0D47A1
}

' ============================================================
' NETLOCK — read-only, via Dapper. Never migrated by ControlIT.
' ============================================================

package "NetLock (read-only — Dapper)" #FFF8E1 {

  class tenants <<netlock>> {
    + PK id : int
    guid : string
    name : string
    date : string
    author : string
    description : string
    company : string
    contact_person_one..five : string
  }

  class locations <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    guid : string
    name : string
    description : string
  }

  class clients <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    guid : string
    name : string
    description : string
  }

  class devices <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    + FK location_id : int
    access_key : string
    device_name : string
    hwid : string
    platform : string
    operating_system : string
    agent_version : string
    ip_address_internal : string
    ip_address_external : string
    last_access : string
    authorized : int
    synced : int
    .. 30+ telemetry columns ..
  }

  class events <<netlock>> {
    + PK id : int
    + FK device_id : int
    date : string
    severity : string
    reported_by : string
    _event : string  // <-- alias required
    description : string
    type : int
  }

  class policies <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    description : string
    author : string
    updated : string
    json : text
  }

  class automations <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    description : string
    json : text
  }

  class scripts <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    description : string
    platform : string
    language : string
    content : longtext
  }

  class jobs <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    + FK device_id : int
    name : string
    status : string
    scheduled_at : string
    result : text
  }

  class sensors <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    type : string
    json : text
  }

  class files <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    size : bigint
    sha256 : string
    uploaded_at : string
    .. bytes served by NetLock file server ..
  }

  class agent_package_configurations <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    platform : string
    arch : string
    server_config : text
  }

  ' ----- notification channels (5 sibling tables, secrets scrubbed) -----
  class mail_notifications <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    smtp_host : string
    smtp_port : int
    from_address : string
    // <color:red>smtp_password</color>  NEVER SERIALISED
  }
  class microsoft_teams_notifications <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    // <color:red>webhook_url</color>  NEVER SERIALISED
  }
  class ntfy_sh_notifications <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    topic : string
    // <color:red>bearer_token</color>  NEVER SERIALISED
  }
  class telegram_notifications <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    chat_id : string
    // <color:red>bot_token</color>  NEVER SERIALISED
  }
  class webhook_notifications <<netlock>> {
    + PK id : int
    + FK tenant_id : int
    name : string
    // <color:red>url</color>  NEVER SERIALISED
    // <color:red>signing_secret</color>  NEVER SERIALISED
  }
}

' ============================================================
' CONTROLIT-OWNED — EF Core migrations only. controlit_* prefix.
' ============================================================

package "ControlIT owned (EF Core — controlit_*)" #E8F5E9 {

  class controlit_audit_log <<controlit>> {
    + PK id : bigint
    logged_at : datetime
    + FK tenant_id : int
    actor_key_id : string  // hashed user id pre-05B; user_id post-05B
    + FK user_id : int?      // new in 05B
    action : string
    resource_type : string
    resource_id : string
    ip_address : string
    result : string
    error_message : string
  }

  class controlit_device_map <<controlit>> {
    + PK id : int
    + FK client_id : int
    + FK netlock_agent_id : int
    netbird_peer_id : string?
    wazuh_agent_id : string?
  }
}

' ============================================================
' CONTROLIT-OWNED (auth — Contract 05B)
' ============================================================

package "ControlIT auth (EF Core — 05B)" #E3F2FD {

  class controlit_users <<auth>> {
    + PK id : int
    + U email : string(256)      // case-insensitive unique
    password_hash : string(200)  // bcrypt, work factor 12
    role : tinyint               // enum Role
    + FK tenant_id : int?        // required for ClientAdmin, null for Cp/Super
    assigned_clients : json?     // Technician only
    is_active : bool
    must_change_password : bool
    password_changed_at : datetime
    failed_login_count : int
    locked_until : datetime?
    created_at : datetime
    last_login_at : datetime?
  }

  class controlit_refresh_tokens <<auth>> {
    + PK id : int
    + FK user_id : int
    + U token_hash : string(64)  // sha-256 of 256-bit random
    expires_at : datetime         // 7 days
    revoked_at : datetime?
    + FK replaced_by : int?      // rotation chain pointer
    created_at : datetime
    user_agent : string(512)?
    ip_address : string(45)?
  }

  class controlit_password_reset_tokens <<auth>> {
    + PK id : int
    + FK user_id : int
    + U token_hash : string(64)
    expires_at : datetime         // 1 hour
    used_at : datetime?
    created_at : datetime
  }
}

