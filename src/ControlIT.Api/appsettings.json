{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ControlIT.Api.Infrastructure.NetLock": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "http://localhost:3000"
  },
  "ConnectionStrings": {
    // This connects to the same MySQL instance that NetLock uses.
    // The controlit user should have SELECT on NetLock tables + full access to controlit_* tables.
    "ControlIt": "Server=localhost;Port=3306;Database=netlock;User=controlit;Password=CHANGEME;"
  },
  "Database": {
    // Must match the MySQL database name above — used by NetLockSchemaValidator.
    "Name": "netlock"
  },
  "NetLock": {
    // The URL of NetLock's SignalR command hub — where ControlIT connects as an admin client.
    "HubUrl": "http://localhost:7080/commandHub",
    // The remote_session_token from NetLock's accounts table for the admin account.
    // Find this by running: SELECT remote_session_token FROM accounts WHERE is_admin = 1 LIMIT 1;
    "AdminSessionToken": "REPLACE_WITH_REMOTE_SESSION_TOKEN_FROM_ACCOUNTS_TABLE"
  },
  "Netbird": {
    // The base URL of your Netbird management server (self-hosted or cloud).
    "BaseUrl": "https://your-netbird-management-server",
    // A Personal Access Token (PAT) from the Netbird dashboard.
    // Used as "Authorization: Token <TOKEN>" — NOT Bearer.
    "Token": "REPLACE_WITH_NETBIRD_PAT"
  },
  "Wazuh": {
    // Set to true only when Phase 2 is deployed with a running Wazuh instance.
    "Enabled": false,
    "BaseUrl": "",
    "Token": ""
  }
}
