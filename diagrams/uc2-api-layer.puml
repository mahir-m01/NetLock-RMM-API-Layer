@startuml UC2-API-Layer
' ============================================================
' UC-2: ControlIT.Api — REST API Layer Drill-Down (v2 — post 05 + 05B)
' Scope : ControlIT.Api internals — how the API layer satisfies
'         use cases, JWT auth enforcement, sync vs async distinction,
'         phase boundaries, external system dependencies per group.
' v2 changes:
'   - New Group 0 (Authentication) from Contract 05B.
'   - Old Group 2 "API Key" use cases replaced by JWT validation;
'     every group's <<include>> now points to Validate JWT.
'   - Group 4 expanded with file browser, services, task manager,
'     power, event log (Contract 05 §5.3).
' Convention: Primary actors LEFT, secondary RIGHT.
' ============================================================

title UC-2: ControlIT.Api — REST API Layer Drill-Down (v2)

left to right direction

skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam usecase {
  BackgroundColor #DDEEFF
  BorderColor #336699
  ArrowColor #336699
  ActorBackgroundColor #FFEFCD
  ActorBorderColor #AA6622
}

skinparam rectangle {
  BackgroundColor #FAFAFA
  BorderColor #1a1a2e
  BorderThickness 2
}

skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #AA8800
}

' ============================================================
' LEFT — Primary Actors (callers / initiators)
' ============================================================

actor "Dashboard User" as DashUser
actor "Control IT\nDashboard\n(Next.js)" as Dashboard <<system>>
actor "Attacker\n[stolen token]" as Attacker <<threat>>

DashUser --> Dashboard

' ============================================================
' SYSTEM BOUNDARY
' ============================================================

rectangle "ControlIT.Api  (ASP.NET Core 10 — Minimal APIs)" {

  ' ── Group 0: Authentication (NEW — Contract 05B) ───────
  package "0 — Authentication\n[Contract 05B]" #E8F5E9 {
    usecase "POST /auth/login" as UCLogin
    usecase "POST /auth/refresh" as UCRefresh
    usecase "POST /auth/logout" as UCLogout
    usecase "POST /auth/change-password" as UCChangePwd
    usecase "POST /auth/forgot-password" as UCForgotPwd
    usecase "POST /auth/reset-password" as UCResetPwd
    usecase "GET  /auth/me" as UCMe
    usecase "Manage Users\n(/users CRUD)" as UCUsers
    usecase "Force Password Reset\n(/users/{id}/force-password-reset)" as UCForceReset
  }

  ' ── Group 1: Startup & Health ──────────────────────────
  package "1 — Startup & Health\n[Phase 1]" #DDEECC {
    usecase "Validate NetLock\nSchema" as UCSchema
    usecase "Connect to\nSignalR Hub" as UCConnect
    usecase "Health Check" as UCHealth
    usecase "Handle Schema\nMismatch" as UCMismatch
    usecase "Bootstrap SuperAdmin\non Empty DB" as UCBootstrap
  }

  ' ── Group 2: JWT + Authorization (REPLACES old API-key group) ─
  package "2 — Auth Validation & Authorization\n[cross-cutting — 05B]" #ECEFF1 {
    usecase "Validate JWT" as UCValidJwt
    usecase "Resolve ClaimsPrincipal\nto Actor/Tenant" as UCResolveActor
    usecase "Enforce Policy\n(SuperAdminOnly, CpAdminOrAbove,\nTenantMember, CanExecuteCommands)" as UCPolicy
  }

  ' ── Group 3: Device / Read queries ──────────────────────
  package "3 — Device Queries & NetLock Reads\n[sync — DB reads, tenant-scoped]\n[Contract 05 §5.2]" #DDEEFF {
    usecase "GET /devices" as UCListDev
    usecase "GET /devices/{id}" as UCGetDev
    usecase "GET /devices/unauthorised" as UCUnauth
    usecase "GET /tenants" as UCTenants
    usecase "GET /clients" as UCClients
    usecase "GET /policies" as UCPolicies
    usecase "GET /automations" as UCAutos
    usecase "GET /scripts" as UCScripts
    usecase "GET /jobs" as UCJobs
    usecase "GET /sensors" as UCSensors
    usecase "GET /files" as UCFiles
    usecase "GET /installer-configs" as UCInstallers
    usecase "GET /notification-channels\n(secrets scrubbed)" as UCNotifs
    usecase "GET /dashboard" as UCDash
  }

  ' ── Group 4: Command Dispatch (EXPANDED — 05 §5.3) ─────
  package "4 — Command Dispatch\n[async — SignalR, Option D per call]\n[Contract 05 §5.3]" #FFF3E0 {
    usecase "POST /commands/execute\n(remote shell)" as UCExec
    usecase "Browse Remote Files\n(POST /commands/files/*)" as UCFileBrowse
    usecase "Manage Services\n(POST /commands/services/{action})" as UCServices
    usecase "Kill Process\n(POST /commands/processes/kill)" as UCKill
    usecase "Power Action\n(POST /commands/power/{op})" as UCPower
    usecase "View Event Log\n(POST /commands/events/query)" as UCEventLog
    usecase "Virtual Display\n(POST /commands/virtual-display/*)" as UCVirtDisp
    usecase "Tray Chat\n(POST /commands/tray-chat)" as UCTrayChat
    usecase "Handle Command\nTimeout" as UCCmdTimeout
    usecase "Handle SignalR\nDisconnected" as UCDisconnect
  }

  ' ── Group 5: Device Management (NEW — 05 §5.4) ─────────
  package "5 — Device Management\n[05 §5.4 — NetLock admin REST passthrough]" #E1F5FE {
    usecase "POST /devices/{id}/move" as UCMove
    usecase "PUT  /devices/{id}/label" as UCLabel
    usecase "POST /devices/{id}/approve" as UCApprove
    usecase "POST /devices/{id}/reject" as UCReject
  }

  ' ── Group 6: Network (Netbird) — Phase 1 ───────────────
  package "6 — Network Queries\n[sync — Netbird REST]" #DDEEEE {
    usecase "GET /network/peers" as UCPeers
    usecase "POST /network/policy\n[Contract 06]" as UCNetPolicy
    usecase "DELETE /network/peer/{id}" as UCDelPeer
  }

  ' ── Group 7: Events & Alerts ───────────────────────────
  package "7 — Events & Alerts" #E8EAF6 {
    usecase "GET /events" as UCEvents
    usecase "GET /alerts/wazuh\n[Phase 2]" as UCWazuhAlerts
    usecase "POST /alerts/acknowledge\n[Phase 2]" as UCAck
  }

  ' ── Group 8: Audit Log ─────────────────────────────────
  package "8 — Audit Log\n[cross-cutting]" #ECEFF1 {
    usecase "GET /audit/logs" as UCAuditGet
    usecase "GET /audit/logs/export" as UCAuditExport
    usecase "Record Audit\nEvent" as UCRecord
  }

  ' ── Group 9: Device Identity (05 §5.5) ─────────────────
  package "9 — Device Identity\n[05 §5.5]" #FFF8E1 {
    usecase "Reconcile Device Identity\n(background IHostedService)" as UCReconcile
    usecase "GET /identity/resolve" as UCIdResolve
    usecase "POST /identity/override" as UCIdOverride
  }

  ' ── Rate Limiting ──────────────────────────────────────
  package "Rate Limiting\n[threat mitigation]" #FFEBEE {
    usecase "Rate Limit / Block" as UCRateLimit
  }
}

