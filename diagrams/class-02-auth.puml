    +IsAllTenants : bool
    .. null TenantId means CpAdmin/SuperAdmin — all tenants ..
  }
  class ReconciliationService <<HostedService>>
  class AuditingRepositoryDecorator <<Decorator>>
}

IClock        <|.. SystemClock
IActorContext <|.. HttpActorContext
IAuditService <|.. AuditService
HttpActorContext ..> Role : exposes
AuditService --> IClock
AuditService --> AuditRepository
ReconciliationService --> IDeviceRepository
ReconciliationService --> ControlItDbContext : upserts DeviceMap
ControlItFacade --> IDeviceRepository
ControlItFacade --> IEventRepository
ControlItFacade --> INetLockAdminClient
ControlItFacade --> IAuditService
AuditingRepositoryDecorator ..> IAuditService
AuditingRepositoryDecorator ..> IActorContext
AuditingRepositoryDecorator --> ICommandDispatcher : wraps (optional)

' ============================================================
' 11 — AUTHORIZATION POLICIES (05B)
' ============================================================

package "Common.Authorization (05B)" #FFECB3 {
  class "SuperAdminOnly"     as PolSA <<Policy>>
  class "CpAdminOrAbove"     as PolCP <<Policy>>
  class "TenantMember"       as PolTM <<Policy>>
  class "CanExecuteCommands" as PolCC <<Policy>>

  note right of PolCC
    Roles: SuperAdmin | CpAdmin | Technician
    Applied to: /commands/*, /devices/{id}/move,
    /devices/{id}/label, /devices/{id}/approve,
    /devices/{id}/reject
  end note
  note right of PolTM
    Any authenticated user with non-null tenant_id,
    OR CpAdmin/SuperAdmin (all tenants).
    Applied to: /devices, /events, /audit, /dashboard
  end note
}

