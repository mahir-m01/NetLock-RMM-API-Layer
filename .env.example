# ControlIT Environment Template
# Run ./scripts/setup-controlit-env.sh to create .env with generated secrets.

# Existing NetLock/MySQL values. Standard NetLock Docker installs are auto-detected.
# ControlIT setup does not install, start, or modify NetLock.
MYSQL_ROOT_PASSWORD=REPLACE_WITH_AUTO_DISCOVERED_NETLOCK_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=iphbmh
MYSQL_CONTAINER=mysql-container
CONTROLIT_DB_HOST=mysql-container
CONTROLIT_DB_PORT=3306
NETLOCK_DOCKER_NETWORK=netlock-rmm-api-layer_netlock-network
MEMBERS_PORTAL_API_KEY=get-from-members.netlockrmm.com
TZ=Asia/Kolkata

# ─── ControlIT ────────────────────────────────────────────────────────────────
CONTROLIT_JWT_SIGNING_KEY=GENERATED_BY_SETUP_SCRIPT
CONTROLIT_BOOTSTRAP_EMAIL=admin@yourdomain.local
CONTROLIT_BOOTSTRAP_PASSWORD=GENERATED_BY_SETUP_SCRIPT
CONTROLIT_NETLOCK_TOKEN=REPLACE_WITH_AUTO_DISCOVERED_NETLOCK_REMOTE_SESSION_TOKEN
CONTROLIT_NETLOCK_FILES_KEY=REPLACE_WITH_AUTO_DISCOVERED_NETLOCK_FILES_API_KEY
CONTROLIT_NETLOCK_HUB_URL=http://netlock-rmm-server:7080/commandHub
CONTROLIT_AUTO_MIGRATE=false
CONTROLIT_PUBLIC_API_URL=http://localhost:5290
CONTROLIT_ALLOWED_ORIGINS=http://localhost:3000
CONTROLIT_API_PORT=5290
CONTROLIT_WEB_PORT=3000
CONTROLIT_NETLOCK_BRIDGE_INTERVAL_SECONDS=5
CONTROLIT_NETLOCK_BRIDGE_PAGE_SIZE=500

# Netbird Management API. Use self-hosted URL or Netbird cloud URL.
# Auth scheme is "Authorization: Token <NETBIRD_TOKEN>" inside ControlIT.
NETBIRD_BASE_URL=https://api.netbird.io
NETBIRD_TOKEN=REPLACE_WITH_NETBIRD_PERSONAL_ACCESS_TOKEN

# Database credentials for the dedicated ControlIT API user (not root).
# See scripts/init-controlit-db-user.sql to create this user in MySQL.
CONTROLIT_DB_USER=controlit_api
CONTROLIT_DB_PASSWORD=GENERATED_BY_SETUP_SCRIPT
