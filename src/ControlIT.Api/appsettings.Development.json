{
  // Development overrides — more verbose logging.
  // Secrets (DB connection string, AdminSessionToken) are stored in dotnet user-secrets.
  // Run: dotnet user-secrets list --project src/ControlIT.Api/ControlIT.Api.csproj
  //
  // IMPORTANT — AdminSessionToken goes stale on every Docker container restart.
  // NetLock regenerates remote_session_token in the accounts table each time.
  // After any restart run:
  //
  //   ./scripts/refresh-token.sh
  //
  // That script writes the live token to user-secrets automatically.
  // Alternatively export CONTROLIT_NETLOCK_TOKEN=<token> before dotnet run
  // and Program.cs will use the env var instead.
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "ControlIT.Api": "Debug"
    }
  }
}
