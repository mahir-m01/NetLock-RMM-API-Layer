package "Common.Middleware" #FFEBEE {
  class JwtBearerMiddleware <<Middleware>> {
    .. built-in AddJwtBearer — HS256, validates ..
    .. iss/aud/exp/nbf/sig, populates ClaimsPrincipal ..
  }
  class ErrorHandlingMiddleware <<Middleware>>
  class ApiKeyMiddleware <<deprecated>> {
    .. removed from pipeline in 05B §5B.3 ..
  }
}

JwtBearerMiddleware ..> HttpActorContext : fills ClaimsPrincipal

