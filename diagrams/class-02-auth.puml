' ============================================================
' 8 — INFRASTRUCTURE: NETLOCK (Option-D dispatcher hierarchy)
' ============================================================

package "Infrastructure.NetLock" #FFF3E0 {

  class NetLockSignalRService <<HostedService>> {
    -_options : NetLockOptions
    -_schemaValidator : ISchemaValidator
    -_logger : ILogger
    -_longLivedConnection : HubConnection
    +IsConnected : bool
    +StartAsync(ct) : Task
    +StopAsync(ct) : Task
    +AcquireAdminConnectionAsync(ct) : Task<HubConnection>
    .. Singleton retains: schema validation, reconnect policy, ..
    .. long-lived admin connection for NetLockAdminClient health  ..
  }

  class NetLockAdminClient <<HttpClient>>
  class InfiniteRetryPolicy

  abstract class CommandDispatcherBase <<abstract>> {
    #_signalR : NetLockSignalRService
    #_factory : IDbConnectionFactory
    #_clock : IClock
    #_logger : ILogger
    #{abstract} HubMethodName : string
    #_timeout : TimeSpan
    +InvokeAsync(accessKey, commandJson, ct) : Task<string>
    #{abstract} ParseCallback(raw: string) : (deviceIdKey: string, payload: string)
    #LookupDeviceIdAsync(accessKey, tenantId) : Task<string>
    .. Option D: each call acquires its OWN short-lived HubConnection, ..
    .. registers its OWN .On<string>(HubMethodName, ...) handler, ..
    .. invokes, awaits, disposes. No shared _pending dictionary. ..
  }

  class RemoteShellDispatcher {
    #HubMethodName = "ReceiveClientResponseRemoteShell"
    #ParseCallback(raw) : split on ">>nlocksep<<"
  }
  class FileBrowserDispatcher {
    #HubMethodName = "ReceiveClientResponseRemoteFileBrowser*"
    #ParseCallback(raw) : per-op parser, fileOp enum selects method name
  }
  class ServiceActionDispatcher {
    #HubMethodName = "ReceiveClientResponseServiceAction"
  }
  class TaskManagerDispatcher {
    #HubMethodName = "ReceiveClientResponseTaskManagerAction"
  }
  class PowerManagementDispatcher {
    #HubMethodName = "ReceiveClientResponsePowerManagementAction"
  }
  class EventLogDispatcher {
    #HubMethodName = "ReceiveClientResponseRemoteEventlogViewer"
  }
  class VirtualDisplayDispatcher {
    #HubMethodName = "ReceiveClientResponseVirtualDisplay"
  }
  class TrayChatDispatcher {
    #HubMethodName = "ReceiveClientResponseTrayIconChatMessage"
  }
}

CommandDispatcherBase <|-- RemoteShellDispatcher
CommandDispatcherBase <|-- FileBrowserDispatcher
CommandDispatcherBase <|-- ServiceActionDispatcher
CommandDispatcherBase <|-- TaskManagerDispatcher
CommandDispatcherBase <|-- PowerManagementDispatcher
CommandDispatcherBase <|-- EventLogDispatcher
CommandDispatcherBase <|-- VirtualDisplayDispatcher
CommandDispatcherBase <|-- TrayChatDispatcher

IRemoteShellDispatcher       <|.. RemoteShellDispatcher
IFileBrowserDispatcher       <|.. FileBrowserDispatcher
IServiceActionDispatcher     <|.. ServiceActionDispatcher
ITaskManagerDispatcher       <|.. TaskManagerDispatcher
IPowerManagementDispatcher   <|.. PowerManagementDispatcher
IEventLogDispatcher          <|.. EventLogDispatcher
IVirtualDisplayDispatcher    <|.. VirtualDisplayDispatcher
ITrayChatDispatcher          <|.. TrayChatDispatcher

CommandDispatcherBase --> NetLockSignalRService : AcquireAdminConnectionAsync
CommandDispatcherBase --> IDbConnectionFactory
CommandDispatcherBase --> IClock
NetLockSignalRService --> ISchemaValidator
NetLockSignalRService --> InfiniteRetryPolicy
INetLockAdminClient <|.. NetLockAdminClient
NetLockAdminClient --> NetLockSignalRService : long-lived conn for\n/admin/devices/connected

' ============================================================
' 9 — INFRASTRUCTURE: AUTH (05B)
' ============================================================

package "Infrastructure.Auth (05B)" #E8F5E9 {

  class JwtService {
    -_signingKey : byte[]
    -_issuer : string
    -_audience : string
    -_clock : IClock
    +IssueAccessToken(user) : string
  }

  class BCryptPasswordHasher {
    -_workFactor = 12
    +Hash(plaintext) : string
    +Verify(plaintext, hash) : bool
  }

  class AuthService {
    -_users : IUserRepository
    -_refreshTokens : IRefreshTokenRepository
    -_resetTokens : IPasswordResetTokenRepository
    -_jwt : IJwtService
    -_hasher : IPasswordHasher
    -_clock : IClock
    -_audit : IAuditService
    +LoginAsync / RefreshAsync / LogoutAsync /
    +ChangePasswordAsync / RequestPasswordResetAsync /
    +ResetPasswordAsync
    .. lockout after 5 failures (30min) ..
    .. refresh rotation + replay-chain revocation ..
    .. policy: >=12 chars, 3 of {U,L,D,S} ..
  }

  class BootstrapUserSeeder <<HostedService>> {
    +StartAsync(ct) : Task
    .. if no users, seed SuperAdmin from env vars ..
    .. CONTROLIT_BOOTSTRAP_EMAIL / CONTROLIT_BOOTSTRAP_PASSWORD ..
    .. MustChangePassword = true on seed ..
  }
}

IJwtService        <|.. JwtService
IPasswordHasher    <|.. BCryptPasswordHasher
IAuthService       <|.. AuthService
AuthService --> IUserRepository
AuthService --> IRefreshTokenRepository
AuthService --> IPasswordResetTokenRepository
AuthService --> IJwtService
AuthService --> IPasswordHasher
AuthService --> IClock
AuthService --> IAuditService
BootstrapUserSeeder --> IUserRepository
BootstrapUserSeeder --> IPasswordHasher
JwtService --> IClock

